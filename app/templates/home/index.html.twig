{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}

<div class="container my-5">

    <div class="accordion" id="accordionExample">

        {# Premier item avec un bouton qui ouvre la modale #}
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                    Accordion Item #1
                </button>
            </h2>
            <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#accordionExample">
                <div class="accordion-body">
                    <p>Clique sur le bouton ci-dessous pour ouvrir la modale :</p>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#maModale">
                        Ouvrir la modale
                    </button>
                </div>
            </div>
        </div>

        {# Deuxième item avec carousel + textes en colonnes #}
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                    Accordion Item #2
                </button>
            </h2>
            <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
                <div class="accordion-body">

                    {# Carousel centré, rétréci et avec bordure arrondie #}
                    <div class="row justify-content-center mb-4">
                        <div class="col-12 col-md-8 col-lg-6">
                            <div id="carouselExample" class="carousel slide border rounded overflow-hidden" data-bs-ride="carousel">
                                <div class="carousel-inner">
                                    <div class="carousel-item active">
                                        <img src="{{ asset('images/dragon.jpg') }}" class="d-block w-100" alt="Dragon" style="height: 400px; object-fit: cover;">
                                    </div>
                                    <div class="carousel-item">
                                        <img src="{{ asset('images/cowboy.png') }}" class="d-block w-100" alt="Cowboy" style="height: 400px; object-fit: cover;">
                                    </div>
                                    <div class="carousel-item">
                                        <img src="{{ asset('images/bird.jpg') }}" class="d-block w-100" alt="Bird" style="height: 400px; object-fit: cover;">
                                    </div>
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Previous</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Next</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    {# 3 paragraphes en colonnes centrés #}
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <p class="text-center border p-3 h-100 mb-0">Lorem ipsum, dolor sit amet consectetur adipisicing elit. Quae excepturi error ex eligendi eaque dolore quasi et officia nihil magni quam reprehenderit dolor natus.</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <p class="text-center border p-3 h-100 mb-0">Lorem ipsum dolor sit amet consectetur adipisicing elit. Necessitatibus possimus eos enim neque quam itaque ad illo cum laboriosam assumenda.</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <p class="text-center border p-3 h-100 mb-0">Lorem ipsum dolor sit amet consectetur adipisicing elit. Tenetur tempore dolorem iure odio nesciunt, repellendus deserunt, suscipit aspernatur perspiciatis corporis consectetur consequatur maiores ad!</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>

</div>

{# Modale en dehors de l'accordéon #}
<div class="modal fade" id="maModale" tabindex="-1" aria-labelledby="maModaleLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="maModaleLabel">Confirmation de votre choix</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Voulez-vous confirmer votre choix ?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary">Confirmer</button>
            </div>
        </div>
    </div>
</div>

{% endblock %}
